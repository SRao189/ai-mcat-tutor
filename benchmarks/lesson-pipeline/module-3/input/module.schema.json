{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCAT Course Module",
  "type": "object",
  "required": [
    "id",
    "title",
    "objectives",
    "sections",
    "equations",
    "workedExamples",
    "checks",
    "practiceQuestions",
    "sourceRefs",
    "sourceGaps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "content",
          "sourceRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "minLength": 1
          },
          "sourceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "equations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "expression",
          "meaning",
          "sourceRefs"
        ],
        "properties": {
          "expression": {
            "type": "string",
            "minLength": 1
          },
          "meaning": {
            "type": "string",
            "minLength": 1
          },
          "sourceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "workedExamples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question",
          "steps",
          "answer",
          "sourceRefs"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "answer": {
            "type": "string",
            "minLength": 1
          },
          "sourceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "practiceQuestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceGaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": [
        "question",
        "answer",
        "explanation",
        "sourceRefs",
        "reviewTarget"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewTarget": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
