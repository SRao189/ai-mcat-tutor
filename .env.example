# NVIDIA Build API configuration.
# Copy to .env locally if needed. Never commit real values.

NVIDIA_API_KEY=replace-with-your-nvidia-build-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TUTOR_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_RERANK_MODEL=replace-after-endpoint-audit
NVIDIA_SAFETY_MODEL=nvidia/nemotron-content-safety-reasoning-4b

# Tests and offline development use this to avoid API calls.
NVIDIA_MOCK_MODE=true

# Open Notebook local service configuration.
API_BASE_URL=http://127.0.0.1:5055
API_CLIENT_TIMEOUT=300
OPEN_NOTEBOOK_PASSWORD=
OPEN_NOTEBOOK_ENCRYPTION_KEY=replace-with-a-local-dev-secret
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook
